/**
 * TioSEUS Colorscheme for Rofi
 * Paleta: azul #007acc + dourado #c9a063 + fundo escuro
 */

* {
    background:     #0a0e14FF;
    background-alt: #121f35FF;
    foreground:     #b3b1adFF;
