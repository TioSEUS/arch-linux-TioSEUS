## TioSEUS CAVA Configuration
## Gradiente: dourado → azul → vermelho (paleta TioSEUS)

[general]

# Frames por segundo
framerate = 60

# Auto-sensibilidade
autosens = 1
overshoot = 20

# Sensibilidade inicial (%)
sensitivity = 100

# Número de barras (0 = auto)
bars = 0
bar_width = 2
bar_spacing = 1

# Largura/altura para noritake
bar_height = 32

# Cutoff de frequências
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

# Sleep timer
sleep_timer = 5


[input]

# PipeWire (recomendado no Hyprland)
method = pipewire
source = auto


[output]

# Método de saída
method = noncurses

# Orientação
orientation = bottom

# Canais
channels = stereo
mono_option = average
reverse = 0

# Raw output
raw_target = /dev/stdout
data_format = binary
bit_format = 16bit

# SDL (se usar sdl_glsl)
sdl_width = 1000
sdl_height = 500
sdl_x = -1
sdl_y = -1
sdl_full_screen = 0

# Eixo X
xaxis = none

# Alacritty sync
alacritty_sync = 0

# Shaders para sdl_glsl
; vertex_shader = pass_through.vert
; fragment_shader = bar_spectrum.frag

; continuous_rendering = 0
; disable_blanking = 0
show_idle_bar_heads = 1
waveform = 0


[color]

# Cores de fundo e frente (modo noncurses usa cores do terminal)
background = default
foreground = default

# SDL/SDL_GLSL cores hex
; background = '#0a0e14'
; foreground = '#007acc'

# MODO GRADIENTE — PALETA TIOSEUS
gradient = 1
gradient_count = 5
gradient_color_1 = '#c9a063'
gradient_color_2 = '#ffd56f'
gradient_color_3 = '#33a1ff'
gradient_color_4 = '#007acc'
gradient_color_5 = '#ff4444'


[smoothing]

# Noise reduction (0-100)
noise_reduction = 77


[eq]

; 1 = 1 # bass
; 2 = 1
; 3 = 1 # midtone
; 4 = 1
; 5 = 1 # treble
